/*
~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
    TB-ML model registry
~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
    Each entry describes one TB-ML-compatible model that can be plugged into
    BACKEND_TB_ML via the 3-stage container pattern (Libiseller-Egger 2023,
    Bioinformatics Advances; doi:10.1093/bioadv/vbad040):

      Stage 1 (probe)      — predictor container in metadata mode emits the
                             target loci it needs (e.g. relevant SNP sites for
                             a CNN trained on one-hot encoded sequences).
      Stage 2 (preprocess) — pre-processor container converts raw reads or BAM
                             into the predictor's expected feature format
                             (one-hot CSV / variants CSV / consensus FASTA).
      Stage 3 (predict)    — predictor container consumes the features and
                             writes per-drug resistance calls to STDOUT/CSV.

    Adding a new model = adding one entry here. No subworkflow code change.

    Containers come from:
      https://tb-ml.github.io/tb-ml-containers/  (published TB-ML containers)
      Docker Hub: julibeg/* and jodyphelan/*

    Pin every container by tag (digest pinning is a Phase-2 hardening pass —
    see docs/RELATED_WORK.md § Pending follow-up).
----------------------------------------------------------------------------------------
*/

params {

    // ============================================================
    // Master registry — every TB-ML-compatible model the pipeline
    // can run. Add entries here as new TB-ML containers ship.
    // ============================================================
    tb_ml_models = [

        // ---- CNN models trained on one-hot encoded sequences ----
        // Original TB-AMR-CNN (Deelder, Phelan et al.) — 13 drugs;
        // amikacin, capreomycin, kanamycin, ethambutol, ethionamide,
        // isoniazid, levofloxacin, linezolid, moxifloxacin, ofloxacin,
        // pyrazinamide, rifampicin, streptomycin.
        'tb_amr_cnn': [
            description        : 'TB-AMR-CNN — neural network from one-hot encoded sequences, 13 drugs (Deelder/Phelan)',
            predictor_image    : 'julibeg/tb-ml-neural-net-from-one-hot-encoded-seqs-13-drugs:v0.7.0',
            preprocessor_image : 'julibeg/tb-ml-one-hot-encoded-seqs-from-aligned-reads:v0.7.0',
            input_format       : 'bam',            // pre-processor consumes BAM/BAI
            probe_args         : '--get-target-loci -o loci.csv',
            preprocess_args    : '-r loci.csv -o features.csv',
            predict_args       : 'features.csv',
            output_csv         : 'features.csv',   // file the predictor reads
            adapter_id         : 'tb_amr_cnn',     // key for bin/tb_ml_to_canonical.py
            catalogue_name     : 'TB-AMR-CNN_neural_net_v0.7.0',
            catalogue_version  : 'v0.7.0',
        ],

        // ---- Alternative CNN (Linfeng Wang) — same 13 drugs ----
        'tb_dr_pred_nn': [
            description        : 'tb-dr-pred-nn — alternative CNN for 13 drugs (Wang)',
            predictor_image    : 'linfengwang/tb-dr-pred-nn:latest',
            preprocessor_image : 'julibeg/tb-ml-one-hot-encoded-seqs-from-aligned-reads:v0.7.0',
            input_format       : 'bam',
            probe_args         : '--get-target-loci -o loci.csv',
            preprocess_args    : '-r loci.csv -o features.csv',
            predict_args       : 'features.csv',
            output_csv         : 'features.csv',
            adapter_id         : 'tb_dr_pred_nn',
            catalogue_name     : 'tb-dr-pred-nn',
            catalogue_version  : 'latest',
        ],

        // ---- aggreen-MTB-CNN ----
        'aggreen_mtb_cnn': [
            description        : 'aggreen-MTB-CNN — CNN for 13 drugs',
            predictor_image    : 'julibeg/tb-ml-aggreen-mtb-cnn:latest',
            preprocessor_image : 'julibeg/tb-ml-one-hot-encoded-seqs-from-aligned-reads:v0.7.0',
            input_format       : 'bam',
            probe_args         : '--get-target-loci -o loci.csv',
            preprocess_args    : '-r loci.csv -o features.csv',
            predict_args       : 'features.csv',
            output_csv         : 'features.csv',
            adapter_id         : 'aggreen_mtb_cnn',
            catalogue_name     : 'aggreen-MTB-CNN',
            catalogue_version  : 'latest',
        ],

        // ---- Random forest model — streptomycin only ----
        // Different pre-processor: takes variants CSV, not one-hot.
        'rf_streptomycin': [
            description        : 'Random forest from variants — streptomycin only',
            predictor_image    : 'julibeg/tb-ml-random-forest-from-variants-streptomycin:latest',
            preprocessor_image : 'julibeg/tb-ml-variants-from-aligned-reads:latest',
            input_format       : 'bam',
            probe_args         : '--get-target-loci -o loci.csv',
            preprocess_args    : '-r loci.csv -o features.csv',
            predict_args       : 'features.csv',
            output_csv         : 'features.csv',
            adapter_id         : 'rf_streptomycin',
            catalogue_name     : 'TB-ML-RF-streptomycin',
            catalogue_version  : 'latest',
        ],

        // ---- Mykrobe wrapped as a TB-ML container ----
        // Direct-association approach; 15 drugs; takes raw reads directly.
        // Note: Mykrobe doesn't follow the standard 3-stage CSV pattern
        // exactly — it produces JSON natively. We treat it as a special
        // case in BACKEND_TB_ML when input_format == 'reads'. Wired in a
        // follow-up commit; placeholder here.
        'mykrobe_tb_ml': [
            description        : 'Mykrobe wrapped as TB-ML container — 15 drugs, direct-association (kmer)',
            predictor_image    : 'jodyphelan/mykrobe:latest',
            preprocessor_image : null,             // takes reads directly; no separate pre-processor
            input_format       : 'reads',          // FASTQ pair
            probe_args         : null,             // no probe stage
            preprocess_args    : null,
            predict_args       : 'predict --sample {sample} -1 {r1} -2 {r2} --format json',
            output_csv         : 'mykrobe.json',
            adapter_id         : 'mykrobe',
            catalogue_name     : 'mykrobe-tb-panel',
            catalogue_version  : 'latest',
        ],
    ]

    // ============================================================
    // Which models to actually run on a given pipeline invocation.
    // Comma-separated list of keys from tb_ml_models above. Each
    // listed model becomes one backend in the consensus layer.
    // ============================================================
    tb_ml_models_enabled = 'tb_amr_cnn'

    // Tools that mount Docker can require this; nf-nomad / abc-cluster
    // also need it to be true for the container to receive the input files.
    tb_ml_runtime        = 'docker'   // 'docker' | 'singularity'  (informational)
}
